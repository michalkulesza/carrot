# Root env — used by docker compose (compose.yml / compose.prod.yml).
# Copy to .env and fill in real values.

# --- Required ---
SCRAPECREATORS_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash
SEMANTIC_SEARCH_ENABLED=true
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=768
EMBEDDING_DOCUMENT_VERSION=v1
SEMANTIC_SEARCH_SIMILARITY_CUTOFF=0.55
SEMANTIC_SEARCH_MAX_RESULTS=20
EMBEDDING_WORKER_BATCH_SIZE=3
EMBEDDING_RETRY_CAP=6
EMBEDDING_RETRY_BASE_SECONDS=5
EMBEDDING_HNSW_M=16
EMBEDDING_HNSW_EF_CONSTRUCTION=64
ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+asyncpg://platekeeper:${POSTGRES_PASSWORD}@db:5432/platekeeper
SECRET=your_secret_here  # openssl rand -hex 32
POSTGRES_PASSWORD=your_password

# --- Email (Resend — optional; console fallback logs codes when unset) ---
RESEND_API_KEY=          # Resend API key (re_...)
EMAIL_FROM=              # e.g. Carrot <no-reply@yourdomain.com>

# --- R2 image storage (optional — uploads skipped when unset) ---
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=platekeeper-images
R2_PUBLIC_URL=https://<public-bucket>.r2.dev

# --- APNs push notifications (optional — pushes skipped when unset) ---
APNS_KEY_P8=           # Contents of the .p8 file (PEM)
APNS_KEY_ID=           # 10-char key ID from Apple Developer
APNS_TEAM_ID=          # 10-char team ID
APNS_BUNDLE_ID=com.kulesza.carrot
APNS_SANDBOX=true      # false for production
