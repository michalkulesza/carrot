# Web env — Vite (only VITE_-prefixed vars are exposed to the client).
# Copy to .env and fill in real values.

# API base URL. Leave unset (or empty) to use relative /api requests, which
# rely on the vite dev-server proxy (see vite.config.ts) to localhost:8088.
# Set to the production API origin to point the local dev app at prod instead.
# VITE_API_URL=https://api.carrot.xcxz.xyz

# Public R2 bucket URL used to build image/placeholder URLs.
VITE_R2_PUBLIC_URL=https://<public-bucket>.r2.dev
