# Mobile (Expo) development env. Copy to .env.development.
# EXPO_PUBLIC_* vars are bundled into the client. SENTRY_* (without the
# EXPO_PUBLIC_ prefix) are build-time only, used for source-map upload.

# API base URL — use your machine's LAN IP so a physical device can reach it.
EXPO_PUBLIC_API_URL=http://192.168.1.x:8088

# Public R2 bucket URL used to build thumbnail URLs.
EXPO_PUBLIC_R2_PUBLIC_URL=https://<public-bucket>.r2.dev

# --- Sentry (optional) ---
EXPO_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_ORG=your-org
SENTRY_PROJECT=platekeeper
SENTRY_AUTH_TOKEN=your_sentry_auth_token  # build-time source-map upload only
