# API base URL — use your machine's LAN IP so a physical device can reach it.
EXPO_PUBLIC_API_URL=http://localhost:8088
# Optional local-only alternate origin for public sharing. It avoids HTTP/1.1
# connection-pool contention with the app's live update streams.
EXPO_PUBLIC_PUBLIC_SHARE_API_URL=
EXPO_PUBLIC_R2_PUBLIC_URL=https://<public-bucket>.r2.dev

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

EXPO_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_ORG=your-org
SENTRY_PROJECT=platekeeper
SENTRY_AUTH_TOKEN=your_sentry_auth_token  # build-time source-map upload only
